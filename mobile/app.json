{
  "expo": {
    "name": "小x智能记账",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/kitty.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.ecut.aibill",
      "supportsTablet": true,
      "buildNumber": "1"
    },
    "android": {
      "package": "com.ecut.aibill",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#FFE4EC",
        "foregroundImage": "./assets/images/kitty.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/kitty.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "小x智能记账需要访问相册，以便你上传个人头像。"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/kitty.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFE4EC",
          "dark": {
            "backgroundColor": "#2A2226"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ab557427-d310-4ea8-981f-32cccbd2ec68"
      }
    },
    "owner": "prettydoll"
  }
}
