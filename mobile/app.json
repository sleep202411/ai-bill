{
  "expo": {
    "name": "小x智能记账",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/kitty.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFE4EC",
        "foregroundImage": "./assets/images/kitty.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/kitty.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you upload a profile picture."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/kitty.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFE4EC",
          "dark": {
            "backgroundColor": "#2A2226"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
